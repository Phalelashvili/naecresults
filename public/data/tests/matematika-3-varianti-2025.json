i}{3}$</span>","text":"$\\frac{4\\pi}{3}$"}],"correct":"დ","points":1,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"mcq","id":"q34","number":34,"stem_html":"<p>წესიერი სამკუთხა პირამიდის ფუძის გვერდი არის 12 სმ-ის ტოლი, ხოლო გვერდითი ზედაპირის ფართობი არის 72 სმ$^2$. რას უდრის ამ პირამიდის სიმაღლე?</p>","figures":[],"options":[{"letter":"ა","html":"<span>ა) 8 სმ</span>","text":"8 სმ"},{"letter":"ბ","html":"<span>ბ) $\\sqrt{52}$ სმ</span>","text":"$\\sqrt{52}$ სმ"},{"letter":"გ","html":"<span>გ) 4 სმ</span>","text":"4 სმ"},{"letter":"დ","html":"<span>დ) 2 სმ</span>","text":"2 სმ"}],"correct":"დ","points":1,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"mcq","id":"q35","number":35,"stem_html":"<p>იპოვეთ $2; 10; -4; 7; 1; x$ რიცხვითი მონაცემების ჯამი, თუ ამ მონაცემების მედიანა 4-ის ტოლია.</p>","figures":[],"options":[{"letter":"ა","html":"<span>ა) 16</span>","text":"16"},{"letter":"ბ","html":"<span>ბ) 20</span>","text":"20"},{"letter":"გ","html":"<span>გ) 22</span>","text":"22"},{"letter":"დ","html":"<span>დ) 24</span>","text":"24"}],"correct":"გ","points":1,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"mcq","id":"q36","number":36,"stem_html":"<p>$ABCD$ კვადრატს და $BCE$ ტოლგვერდა სამკუთხედს $BC$ გვერდი საერთო აქვთ. $F$ წერტილი წარმოადგენს $CE$ და $BD$ მონაკვეთების გადაკვეთის წერტილს (იხ. სურათი). იპოვეთ $BCF$ სამკუთხედის ფართობის შეფარდება $CFD$ სამკუთხედის ფართობთან.</p>","figures":["media/math-supp/matematika-3-varianti-2025-q36.png"],"options":[{"letter":"ა","html":"<span>ა) $\\sqrt{3} - 1$</span>","text":"$\\sqrt{3} - 1$"},{"letter":"ბ","html":"<span>ბ) $\\frac{\\sqrt{3}}{2}$</span>","text":"$\\frac{\\sqrt{3}}{2}$"},{"letter":"გ","html":"<span>გ) $\\sqrt{2}$</span>","text":"$\\sqrt{2}$"},{"letter":"დ","html":"<span>დ) $\\sqrt{3}$</span>","text":"$\\sqrt{3}$"}],"correct":"დ","points":1,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"mcq","id":"q37","number":37,"stem_html":"<p>კონუსის ფუძის რადიუსი 5 სმ, ხოლო სიმაღლე 12 სმ-ია. ფუძის პარალელური სიბრტყე კონუსს ყოფს ორ ნაწილად. კვეთის შედეგად მიღებული მცირე კონუსის მოცულობა 8-ჯერ ნაკლებია თავდაპირველი კონუსის მოცულობაზე. იპოვეთ მცირე კონუსის გვერდითი ზედაპირის ფართობი.</p>","figures":[],"options":[{"letter":"ა","html":"<span>ა) $\\frac{65\\sqrt{2}\\,\\pi}{4}$ სმ$^2$</span>","text":"$\\frac{65\\sqrt{2}\\,\\pi}{4}$ სმ$^2$"},{"letter":"ბ","html":"<span>ბ) $65\\sqrt{2}\\,\\pi$ სმ$^2$</span>","text":"$65\\sqrt{2}\\,\\pi$ სმ$^2$"},{"letter":"გ","html":"<span>გ) $\\frac{65\\pi}{2}$ სმ$^2$</span>","text":"$\\frac{65\\pi}{2}$ სმ$^2$"},{"letter":"დ","html":"<span>დ) $\\frac{65\\pi}{4}$ სმ$^2$</span>","text":"$\\frac{65\\pi}{4}$ სმ$^2$"}],"correct":"დ","points":1,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"open","id":"q38","number":38,"stem_html":"<p>$m$ პარამეტრის რა მნიშვნელობებისათვის აქვს $x^2 + x + 1 - 3m = 0$ კვადრატულ განტოლებას ორი განსხვავებული ამონახსნი, რომელთა შორის მანძილი რიცხვით ღერძზე ნაკლებია 1-ზე?</p>","figures":[],"options":[],"correct":null,"points":3,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"open","id":"q39","number":39,"stem_html":"<p>წრეწირი, რომლის ცენტრი მდებარეობს $ABC$ მართკუთხა სამკუთხედის $BC$ კათეტზე, გადის $ACB$ მართი კუთხის წვეროზე და $AB$ ჰიპოტენუზას ეხება შუა $D$ წერტილში (იხ. სურათი). იპოვეთ $ABC$ სამკუთხედის ფართობი, თუ წრეწირის რადიუსი $r$-ის ტოლია.</p>","figures":["media/math-supp/matematika-3-varianti-2025-q39.png"],"options":[],"correct":null,"points":3,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"open","id":"q40","number":40,"stem_html":"<p>მომხმარებელმა ბანკში ერთი წლით 1000 ლარი შეიტანა. ხელშეკრულების თანახმად ბანკი ვალდებული იყო შეტანილ თანხაზე ერთი წლის შემდეგ თანხის გარკვეული პროცენტი დაემატებინა. ერთი წლის შემდეგ მომხმარებელმა გამოიტანა მთლიანი (გაზრდილი) თანხა, 200 ლარი სახარჯოდ დაიტოვა, დანარჩენი კი იმავე პირობებით ხელახლა შეიტანა ბანკში. კიდევ ერთი წლის შემდეგ მომხმარებლის ანგარიშზე არსებულმა თანხამ საპროცენტო სარგებლის დამატების შედეგად 990 ლარი შეადგინა. იპოვეთ, შეტანილ თანხს რამდენ პროცენტს ამატებდა ბანკი შეტანილ თანხას ყოველწლიურად.</p>","figures":[],"options":[],"correct":null,"points":4,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false},{"kind":"question","type":"open","id":"q41","number":41,"stem_html":"<p>იპოვეთ $p$ პარამეტრის ყველა იმ მნიშვნელობათა სიმრავლე, რომელთათვისაც არსებობს მართკუთხედი, რომლის პერიმეტრია $p$ მეტრი, ხოლო ფართობია $p$ მ$^2$.</p>","figures":[],"options":[],"correct":null,"points":4,"topic":null,"difficulty":null,"explanation":null,"answerFlag":null,"corrected":false}]}